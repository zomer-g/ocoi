# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./data/ocoi.db
DATABASE_URL_SYNC=sqlite:///./data/ocoi.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ocoi
# DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/ocoi

# Redis
REDIS_URL=redis://localhost:6379/0

# DeepSeek API
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenCorporates
OPENCORPORATES_API_KEY=

# File storage
DATA_DIR=./data
PDF_DIR=./data/pdfs
MARKDOWN_DIR=./data/markdown

# Frontend static files directory (built by: cd frontend && npm run build)
STATIC_DIR=./frontend/out

# CORS — comma-separated allowed origins for external API consumers
ALLOWED_ORIGINS=

# API
API_HOST=0.0.0.0
API_PORT=8000
ENV=development

# Google OAuth (for admin panel)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret

# Admin whitelist (comma-separated Google email addresses)
ADMIN_EMAILS=
